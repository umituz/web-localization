{
  "name": "@umituz/web-localization",
  "version": "1.0.2",
  "description": "Google Translate integrated localization package for web applications",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "type": "module",
  "bin": {
    "web-loc": "./dist/scripts/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./services": "./src/infrastructure/services/index.ts",
    "./utils": "./src/infrastructure/utils/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsc",
    "version:patch": "npm version patch -m 'chore: release v%s'",
    "version:minor": "npm version minor -m 'chore: release v%s'",
    "version:major": "npm version major -m 'chore: release v%s'"
  },
  "keywords": [
    "localization",
    "i18n",
    "google-translate",
    "web"
  ],
  "author": "umituz",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ]
}
